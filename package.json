{
  "name": "@c9up/spectrum",
  "version": "0.1.6",
  "description": "Spectrum — structured logging for the Ream framework",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./provider": {
      "types": "./src/SpectrumProvider.ts",
      "import": "./src/SpectrumProvider.ts"
    },
    "./services/main": {
      "types": "./src/services/main.ts",
      "import": "./src/services/main.ts"
    },
    "./configure": {
      "types": "./src/configure.ts",
      "import": "./src/configure.ts"
    },
    "./testing": {
      "types": "./src/testing/FakeLogger.ts",
      "import": "./src/testing/FakeLogger.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "biome check src/",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@c9up/ream": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./provider": {
        "types": "./dist/SpectrumProvider.d.ts",
        "import": "./dist/SpectrumProvider.js"
      },
      "./services/main": {
        "types": "./dist/services/main.d.ts",
        "import": "./dist/services/main.js"
      },
      "./configure": {
        "types": "./dist/configure.d.ts",
        "import": "./dist/configure.js"
      },
      "./testing": {
        "types": "./dist/testing/FakeLogger.d.ts",
        "import": "./dist/testing/FakeLogger.js"
      }
    },
    "access": "public"
  },
  "peerDependenciesMeta": {
    "@c9up/ream": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/C9up/spectrum.git"
  }
}
